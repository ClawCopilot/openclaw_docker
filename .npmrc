# =========================================
# .npmrc - 完整镜像配置
# 适用于 Node.js 项目，包含所有常见二进制包镜像
# =========================================

# ====================
# 基础镜像配置
# ====================
registry=https://registry.npmmirror.com/

# Node.js 相关镜像
disturl=https://npmmirror.com/mirrors/node
nodedir=https://npmmirror.com/mirrors/node
node_src_dir=https://npmmirror.com/mirrors/node
nodelibcxxdir=https://npmmirror.com/mirrors/node_libcxx

# ====================
# 原生模块二进制镜像
# ====================

# node-sass 相关
sass_binary_site=https://npmmirror.com/mirrors/node-sass
sass_binary_host=https://npmmirror.com/mirrors/node-sass

# Electron 相关
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/

# Python 相关
python_mirror=https://npmmirror.com/mirrors/python

# ====================
# 浏览器驱动镜像
# ====================

# Chrome 相关
chromedriver_cdnurl=https://npmmirror.com/mirrors/chromedriver
CHROMEDRIVER_CDNURL=https://npmmirror.com/mirrors/chromedriver

# Firefox 相关
geckodriver_cdnurl=https://npmmirror.com/mirrors/geckodriver
GECKODRIVER_CDNURL=https://npmmirror.com/mirrors/geckodriver

# Opera 相关
operadriver_cdnurl=https://npmmirror.com/mirrors/operadriver
OPERADRIVER_CDNURL=https://npmmirror.com/mirrors/operadriver

# Edge 相关
edgedriver_cdnurl=https://npmmirror.com/mirrors/edgedriver
EDGEDRIVER_CDNURL=https://npmmirror.com/mirrors/edgedriver

# ====================
# 测试工具镜像
# ====================

# PhantomJS
phantomjs_cdnurl=https://npmmirror.com/mirrors/phantomjs
PHANTOMJS_CDNURL=https://npmmirror.com/mirrors/phantomjs

# Selenium
selenium_cdnurl=https://npmmirror.com/mirrors/selenium
SELENIUM_CDNURL=https://npmmirror.com/mirrors/selenium

# ====================
# 数据库相关镜像
# ====================

# SQLite
sqlite3_binary_host=https://npmmirror.com/mirrors/sqlite3
sqlite3_binary_host_mirror=https://npmmirror.com/mirrors/sqlite3

# PostgreSQL (pg)
pg_binary_host=https://npmmirror.com/mirrors/pg

# ====================
# 图像处理相关镜像
# ====================

# Canvas
canvas_binary_host=https://npmmirror.com/mirrors/canvas
canvas_binary_host_mirror=https://npmmirror.com/mirrors/canvas

# Sharp
sharp_binary_host=https://npmmirror.com/mirrors/sharp
sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp

# ====================
# 加密和压缩相关
# ====================

# bcrypt
bcrypt_binary_host=https://npmmirror.com/mirrors/bcrypt

# node-zopfli
zopfli_binary_host=https://npmmirror.com/mirrors/node-zopfli

# ====================
# 其他常见二进制包
# ====================

# fsevents (macOS)
fsevents_binary_host_mirror=https://npmmirror.com/mirrors/fsevents

# grpc
grpc_binary_host_mirror=https://npmmirror.com/mirrors/grpc

# leveldown
leveldown_binary_host=https://npmmirror.com/mirrors/leveldown

# snappy
snappy_binary_host=https://npmmirror.com/mirrors/snappy

# hiredis
hiredis_binary_host=https://npmmirror.com/mirrors/hiredis

# utf-8-validate
utf-8-validate_binary_host=https://npmmirror.com/mirrors/utf-8-validate

# bufferutil
bufferutil_binary_host=https://npmmirror.com/mirrors/bufferutil

# ====================
# node-gyp 构建配置
# ====================

# Python 配置
python=python3

# 构建工具配置
msvs_version=2019

# 缓存和日志配置
loglevel=verbose
progress=true

# ====================
# 网络和超时配置
# ====================

# 重试配置
fetch-retries=5
fetch-timeout=300000
socket-timeout=300000

# SSL 配置
strict-ssl=false

# ====================
# 开发工具配置
# ====================

# TypeScript
typescript_registry=https://registry.npmmirror.com/

# Webpack
webpack_cli_registry=https://registry.npmmirror.com/

# Babel
babel_registry=https://registry.npmmirror.com/

# ====================
# 其他常用工具和框架镜像
# ====================

# Playwright
playwright_download_host=https://npmmirror.com/mirrors/playwright
PLAYWRIGHT_DOWNLOAD_HOST=https://npmmirror.com/mirrors/playwright

# Puppeteer
puppeteer_download_host=https://npmmirror.com/mirrors/puppeteer
PUPPETEER_DOWNLOAD_HOST=https://npmmirror.com/mirrors/puppeteer

# Cypress
cypress_download_mirror=https://npmmirror.com/mirrors/cypress
CYPRESS_DOWNLOAD_MIRROR=https://npmmirror.com/mirrors/cypress

# Node-pty
node_pty_binary_host=https://npmmirror.com/mirrors/node-pty

# Better-sqlite3
better_sqlite3_binary_host=https://npmmirror.com/mirrors/better-sqlite3

# Node-rdkafka
node_rdkafka_binary_host=https://npmmirror.com/mirrors/node-rdkafka

# Kafka-node
kafka_node_binary_host=https://npmmirror.com/mirrors/kafka-node

# Ibm_db
ibm_db_binary_host=https://npmmirror.com/mirrors/ibm_db

# Oracle
oracle_binary_host=https://npmmirror.com/mirrors/oracle

# Nodejieba
nodejieba_binary_host=https://npmmirror.com/mirrors/nodejieba

# Node-svm
node_svm_binary_host=https://npmmirror.com/mirrors/node-svm

# Zeromq
zeromq_binary_host=https://npmmirror.com/mirrors/zeromq

# Sqlite
sqlite_binary_host=https://npmmirror.com/mirrors/sqlite

# Nodegit
nodegit_binary_host=https://npmmirror.com/mirrors/nodegit

# Keytar
keytar_binary_host=https://npmmirror.com/mirrors/keytar

# Node-ffi
node_ffi_binary_host=https://npmmirror.com/mirrors/node-ffi

# Node-ffi-napi
node_ffi_napi_binary_host=https://npmmirror.com/mirrors/node-ffi-napi

# Ref-napi
ref_napi_binary_host=https://npmmirror.com/mirrors/ref-napi

# Ref-array-napi
ref_array_napi_binary_host=https://npmmirror.com/mirrors/ref-array-napi

# Ref-struct-napi
ref_struct_napi_binary_host=https://npmmirror.com/mirrors/ref-struct-napi

# Iconv
iconv_binary_host=https://npmmirror.com/mirrors/iconv

# Node-expat
node_expat_binary_host=https://npmmirror.com/mirrors/node-expat

# Node-xml2js
node_xml2js_binary_host=https://npmmirror.com/mirrors/node-xml2js

# Node-libxmljs
node_libxmljs_binary_host=https://npmmirror.com/mirrors/node-libxmljs

# Node-sass-china
node_sass_china_binary_host=https://npmmirror.com/mirrors/node-sass-china

# Dart-sass
sass_binary_site=https://npmmirror.com/mirrors/node-sass
dart_sass_binary_site=https://npmmirror.com/mirrors/dart-sass

# Rollup
rollup_binary_host=https://npmmirror.com/mirrors/rollup

# Esbuild
esbuild_binary_site=https://npmmirror.com/mirrors/esbuild

# SWC
swc_binary_site=https://npmmirror.com/mirrors/swc

# Prisma
prisma_binary_site=https://npmmirror.com/mirrors/prisma
prisma_binary_mirror=https://npmmirror.com/mirrors/prisma

# NX
nx_binary_host=https://npmmirror.com/mirrors/nx

# Turbo
turbo_binary_site=https://npmmirror.com/mirrors/turbo

# Biome
biome_binary_site=https://npmmirror.com/mirrors/biome

# Rspack
rspack_binary_site=https://npmmirror.com/mirrors/rspack

# Farm
farm_binary_site=https://npmmirror.com/mirrors/farm

# Vite (esbuild 相关)
vite_binary_site=https://npmmirror.com/mirrors/esbuild

# Terser
terser_binary_host=https://npmmirror.com/mirrors/terser

# UglifyJS
uglifyjs_binary_host=https://npmmirror.com/mirrors/uglifyjs

# Canvas-prebuilt
canvas_prebuilt_binary_host=https://npmmirror.com/mirrors/canvas-prebuilt

# Node-canvas
canvas_binary_host_mirror=https://npmmirror.com/mirrors/canvas

# Gl
gl_binary_host=https://npmmirror.com/mirrors/gl

# Oniguruma
oniguruma_binary_host=https://npmmirror.com/mirrors/oniguruma

# Tree-sitter
tree_sitter_binary_host=https://npmmirror.com/mirrors/tree-sitter

# VSCode (用于插件开发)
vscode_binary_host=https://npmmirror.com/mirrors/vscode

# ====================
# 安全审核配置
# ====================

# 禁用安装时的安全审核（加快安装速度，适用于可信环境）
audit=false