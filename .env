# OpenClaw Docker 环境变量配置



# 基础镜像配置
# BASE_IMAGE: Docker 基础镜像地址
# 默认使用 DaoCloud 镜像加速，也可使用官方源: ghcr.io/openclaw/openclaw:latest
BASE_IMAGE=ghcr.m.daocloud.io/openclaw/openclaw:latest

# OpenClaw 版本配置
# OPENCLAW_VERSION: OpenClaw 安装版本，默认 latest (最新版本)，也可指定版本如 2026.3.24
# 注意：仅当基础镜像未包含 OpenClaw 时生效
OPENCLAW_VERSION=latest

# 容器配置
# CONTAINER_MEM_LIMIT: 容器内存限制，同时设置 mem_limit 和 memswap_limit
# 不设置无任何配置，采用docker默认值，示例: CONTAINER_MEM_LIMIT=8g
CONTAINER_MEM_LIMIT=8g
CONTAINER_RESTART_POLICY=unless-stopped
# CONTAINER_HOME: 容器内用户主目录，默认 /home/node
CONTAINER_HOME=/home/node

# 时区设置
TZ=Asia/Shanghai

# 国内镜像源配置
npm_config_registry=https://registry.npmmirror.com/
pnpm_config_registry=https://registry.npmmirror.com/
git_config_url=https://github.com.cnpmjs.org
# Python pip 镜像 (可选: tuna, aliyun, douban)
PIP_MIRROR=tuna
# Rust 配置
# RUST_VERSION: Rust 版本，默认 stable (最新稳定版)，也可指定版本如 1.75.0
RUST_VERSION=stable
# Rust crates.io 镜像 (可选: tuna, ustc, rsproxy)
RUST_CRATES_MIRROR=tuna
# Go 配置
# GO_VERSION: Go 版本，默认 1.22.0，也可指定其他版本
GO_VERSION=1.22.0
# GOPROXY: Go 模块代理，支持多镜像（逗号分隔，按顺序尝试）
# 可选值: goproxy.cn, goproxy.io, aliyun, direct
# 示例: GOPROXY_MIRRORS=goproxy.cn,goproxy.io,direct
GOPROXY_MIRRORS=goproxy.cn,goproxy.io,direct

# Docker Hub 镜像加速配置
# DOCKER_HUB_MIRRORS: Docker Hub 镜像加速地址，支持多镜像（逗号分隔，按顺序尝试）
# 可选值: daocloud, aliyun, tuna, ustc, 或自定义地址
# 示例: DOCKER_HUB_MIRRORS=daocloud,aliyun,tuna
DOCKER_HUB_MIRRORS=daocloud,aliyun,tuna

# 日志配置
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# 健康检查配置
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_START_PERIOD=5s
HEALTHCHECK_RETRIES=3

# 网络配置
NETWORK_MODE=bridge

# OpenClaw 配置
OPENCLAW_NODE_ENV=production

# 服务配置
# 格式: GATEWAY_SERVICES=service1,service2,service3
# GATEWAY_SERVICES=serv,coder1,coder2,coder3
GATEWAY_SERVICES=sme1,sme2,serv

# 端口配置
# 格式: GATEWAY_PORTS=service1:port1,service2:port2
# 示例: GATEWAY_PORTS=serv:42700,coder1:43801,coder2:43802
GATEWAY_PORTS=

# 额外 volumes 配置
# 格式: GATEWAY_VOLUMES=service1:/host/path1:/container/path1,service2:/host/path2:/container/path2
# 示例: GATEWAY_VOLUMES=serv:/data/volumes:/data, coder1:/opt/data:/app/data
GATEWAY_VOLUMES=
